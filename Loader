-- AUTO COLLECT LOOP
task.spawn(function()
    while true do
        task.wait(0.5)
        if autoAtivo then
            local lista = getTodosShoom()
            btnCount.Text = "🍄 Disponíveis: " .. #lista
            if #lista == 0 then
                task.wait(3)
            else
                for _, item in ipairs(lista) do
                    if not autoAtivo then break end
                    if item.part and item.part.Parent and isColetavel(item.part) then
                        tpEColetar(item.part)
                    end
                end
                task.wait(1)
            end
        else
            local lista = getTodosShoom()
            btnCount.Text = "🍄 Disponíveis: " .. #lista
        end
    end
end)

-- SCANNER
while true do
    task.wait(3)
    for _, v in ipairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not tracked[v] and isShoom(v) then
            tracked[v] = true
            createESP(v)
            v.Destroying:Connect(function() tracked[v] = nil end)
        end
    end
end
